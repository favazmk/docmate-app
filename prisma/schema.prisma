datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  RESCHEDULED
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String?       // Optional for passwordless logins
  phone             String?
  photoUrl          String?       @db.VarChar(500)
  age               Int?
  height            String?
  weight            String?
  bloodGroup        String?
  insuranceProvider String?
  healthConditions  String?       @db.Text
  role              Role          @default(PATIENT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model HospitalGroup {
  id        String   @id @default(uuid())
  name      String   @unique
  photoUrl  String?  @db.VarChar(500)
  aboutUs   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinics   Clinic[]
}

model Clinic {
  id              String        @id @default(uuid())
  hospitalGroupId String
  hospitalGroup   HospitalGroup @relation(fields: [hospitalGroupId], references: [id], onDelete: Cascade)
  name            String        // Branch name (e.g. Dubai Hills Hospital, Jumeirah Clinic)
  city            String        // Dubai, Sharjah, Ajman
  email           String        @default("info@clinic.com")
  phone           String        @default("+971 800 7777")
  photoUrl        String?       @db.VarChar(500)
  aboutUs         String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  doctors         Doctor[]

  @@unique([hospitalGroupId, name])
}

model Specialty {
  id        String   @id @default(uuid())
  name      String   @unique
  iconName  String   @default("Activity")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctors   Doctor[]
}

model Doctor {
  id             String        @id @default(uuid())
  name           String
  slug           String        @unique
  specialtyId    String?
  specialtyRef   Specialty?    @relation(fields: [specialtyId], references: [id], onDelete: SetNull)
  specialty      String        // Fallback/Display compatibility
  photoUrl       String?       @db.VarChar(500)
  rating         Float         @default(5.0)
  reviews        Int           @default(0)
  city           String        // Dubai, Sharjah, Ajman
  email          String        @unique
  clinicId       String?
  clinic         Clinic?       @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  clinicEmail    String        @default("info@clinic.com")
  clinicPhone    String        @default("+971 800 7777")
  languages      String        @default("English")
  gender         String        @default("Male")
  fee            Int
  affiliation    String        // Fallback/Display compatibility
  bio            String        @db.Text
  qualifications String?       @db.Text
  status         String        @default("Active") // Active, Pending
  availableDays  String        @default("Mon - Fri")
  availableTime  String        @default("09:00 AM - 05:00 PM")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  appointments   Appointment[]
  reviewsList    Review[]
}

model Appointment {
  id           String            @id @default(uuid())
  userId       String?
  user         User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctorId     String
  doctor       Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  date         String            // Format: YYYY-MM-DD
  timeSlot     String            // Format: HH:MM AM/PM
  patientName  String
  patientEmail String
  patientPhone String
  reason       String?           @db.Text
  status       AppointmentStatus @default(CONFIRMED)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId])
  @@index([doctorId])
}

model Review {
  id          String   @id @default(uuid())
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patientName String
  rating      Int      // 1 to 5
  comment     String   @db.Text
  createdAt   DateTime @default(now())

  @@index([doctorId])
}
