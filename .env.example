# ============================================================
# DocMate - Environment Variables Example
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
# Your Hostinger MySQL connection string
DATABASE_URL="mysql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_HOSTINGER_HOST:3306/YOUR_DB_NAME"

# --- NextAuth ---
# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
# The URL your app is deployed at (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# --- SMTP Email (for appointment notifications) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-email@gmail.com"
# Use a Gmail App Password, NOT your real Gmail password
SMTP_PASS="xxxx xxxx xxxx xxxx"
ADMIN_EMAIL="admin-notification-recipient@example.com"
