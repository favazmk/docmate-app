{
  "name": "docmate-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node -e \"if (process.platform !== 'win32') require('child_process').execSync('chmod -R 755 app')\"",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "zip": "powershell -Command \"Remove-Item '../docmate-app.zip' -ErrorAction SilentlyContinue; Get-ChildItem -Path . -Exclude 'node_modules','.next','.git' | Compress-Archive -DestinationPath '../docmate-app.zip' -Force\""
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "14.2.35",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "react": "^18",
    "react-dom": "^18",
    "shadcn": "^4.12.0",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
